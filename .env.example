# Gemini API key (CrewAI routes this through LiteLLM automatically
# as long as the model string is prefixed "gemini/")
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini/gemini-2.0-flash

# MongoDB Atlas
# Atlas dashboard -> Database -> Connect -> Drivers -> Python
MONGO_URI=your_mongodb_atlas_connection_string_here
MONGO_DB_NAME=fitcrew_ai

# Optional - only needed if/when the web search tool is enabled later
# SERPER_API_KEY=your_serper_api_key_here

# Single-user app for now (no auth in V1)
DEFAULT_USER_ID=me
